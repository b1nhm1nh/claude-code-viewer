{
  "name": "@ibootz/claude-code-viewer",
  "version": "0.8.2",
  "description": "A full-featured web-based Claude Code client that provides complete interactive functionality for managing Claude Code projects (Bun-native, Windows-compatible fork).",
  "homepage": "https://github.com/ibootz/claude-code-viewer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibootz/claude-code-viewer.git"
  },
  "bin": {
    "claude-code-viewer": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "run-p 'dev:*'",
    "dev:frontend": "vite",
    "dev:backend": "CCV_ENV=development bun --watch src/server/main.ts",
    "start": "bun dist/main.js",
    "build": "bash ./scripts/build.sh",
    "build:frontend": "vite build",
    "build:backend": "bun build src/server/main.ts --target=bun --outdir=dist --sourcemap",
    "lint": "bun run lint:oxlint && bun run lint:oxfmt",
    "lint:oxlint": "oxlint --ignore-path .gitignore",
    "lint:oxfmt": "bun run fix:oxfmt --check",
    "fix": "bun run fix:oxlint && bun run fix:oxfmt",
    "fix:oxlint": "bun run lint:oxlint --fix",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "typecheck": "tsgo --noEmit",
    "test": "bun run vitest --run",
    "test:watch": "bun run vitest",
    "e2e": "./scripts/e2e/exec_e2e.sh",
    "e2e:start-server": "./scripts/e2e/start_server.sh",
    "e2e:capture-snapshots": "./scripts/e2e/capture_snapshots.sh",
    "lingui:extract": "lingui extract --clean && bun ./scripts/lingui-sort.js",
    "lingui:compile": "lingui compile --typescript",
    "release": "bun scripts/release.ts",
    "prepack": "bun run build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.90",
    "@anthropic-ai/claude-code": "2.1.90",
    "@anthropic-ai/sdk": "0.82.0",
    "@effect/cluster": "0.58.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-bun": "0.89.0",
    "@effect/rpc": "0.75.0",
    "@effect/sql": "0.51.0",
    "@effect/workflow": "0.18.0",
    "@hono/zod-validator": "0.7.6",
    "@hookform/resolvers": "5.2.2",
    "@lingui/core": "5.9.4",
    "@lingui/react": "5.9.4",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-devtools": "0.10.1",
    "@tanstack/react-query": "5.96.1",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-router-devtools": "1.166.11",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "commander": "14.0.3",
    "date-fns": "4.1.0",
    "drizzle-orm": "1.0.0-beta.20",
    "effect": "3.21.0",
    "es-toolkit": "1.45.1",
    "hono": "4.12.12",
    "jotai": "2.19.0",
    "lucide-react": "1.7.0",
    "parse-git-diff": "0.0.20",
    "picomatch": "^4.0.4",
    "prexit": "2.3.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "7.72.0",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "ulid": "3.0.2",
    "web-push": "^3.6.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@effect/language-service": "0.84.2",
    "@effect/vitest": "^0.29.0",
    "@lingui/cli": "5.9.4",
    "@lingui/conf": "5.9.4",
    "@lingui/format-json": "5.9.4",
    "@lingui/loader": "5.9.4",
    "@lingui/vite-plugin": "5.9.4",
    "@tailwindcss/postcss": "4.2.2",
    "@tanstack/router-plugin": "1.167.12",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.11",
    "@types/inquirer": "9.0.9",
    "@types/picomatch": "^4.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/web-push": "^3.6.4",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "@vitejs/plugin-react-swc": "4.3.0",
    "changelogithub": "14.0.0",
    "dotenv": "17.4.0",
    "drizzle-kit": "1.0.0-beta.20",
    "gatecheck": "0.0.1-beta.5",
    "inquirer": "13.3.0",
    "jsdom": "^29.0.1",
    "lefthook": "2.1.4",
    "npm-run-all2": "8.0.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "playwright": "1.59.1",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "vite": "8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "4.1.2",
    "webpack": "5.106.1",
    "workbox-build": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "optionalDependencies": {
    "@replit/ruspty": "3.7.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "seroval": ">=1.4.1",
    "tar": ">=7.5.11",
    "undici": ">=7.25.0 <8",
    "yaml": ">=2.8.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core"
  ]
}
