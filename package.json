{
  "name": "@ibootz/claude-code-viewer",
  "version": "0.8.2",
  "description": "A full-featured web-based Claude Code client that provides complete interactive functionality for managing Claude Code projects (Bun-native, Windows-compatible fork).",
  "homepage": "https://github.com/ibootz/claude-code-viewer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibootz/claude-code-viewer.git"
  },
  "bin": {
    "claude-code-viewer": "./dist/main.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n fe,be -c blue,green \"bun run --cwd apps/web dev\" \"bun run --cwd apps/server dev\"",
    "build": "bash ./scripts/build.sh",
    "build:frontend": "bun run --cwd apps/web build",
    "build:backend": "bun run --cwd apps/server build",
    "lint": "bun run lint:oxlint && bun run lint:oxfmt",
    "lint:oxlint": "oxlint --ignore-path .gitignore",
    "lint:oxfmt": "bun run fix:oxfmt --check",
    "fix": "bun run fix:oxlint && bun run fix:oxfmt",
    "fix:oxlint": "bun run lint:oxlint --fix",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "typecheck": "turbo run check",
    "test": "turbo run test",
    "lingui:extract": "bun run --cwd apps/web lingui:extract",
    "lingui:compile": "bun run --cwd apps/web lingui:compile",
    "release": "bun scripts/release.ts",
    "prepack": "bun run build",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/inquirer": "9.0.9",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "changelogithub": "14.0.0",
    "concurrently": "^9.2.1",
    "gatecheck": "0.0.1-beta.5",
    "inquirer": "13.3.0",
    "lefthook": "2.1.4",
    "npm-run-all2": "8.0.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3",
    "seroval": ">=1.4.1",
    "tar": ">=7.5.11",
    "undici": ">=7.25.0 <8",
    "yaml": ">=2.8.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core"
  ]
}
