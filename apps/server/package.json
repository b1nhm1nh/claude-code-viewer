{
  "name": "@ccv/server",
  "private": true,
  "bin": {
    "claude-code-viewer": "./src/main.ts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "CCV_ENV=development bun --watch src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=../../dist --sourcemap",
    "check": "tsgo --noEmit",
    "test": "bun run vitest --run",
    "test:watch": "bun run vitest",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.90",
    "@anthropic-ai/claude-code": "2.1.90",
    "@anthropic-ai/sdk": "0.82.0",
    "@ccv/shared": "workspace:*",
    "@effect/cluster": "0.58.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-bun": "0.89.0",
    "@effect/rpc": "0.75.0",
    "@effect/sql": "0.51.0",
    "@effect/workflow": "0.18.0",
    "@hono/zod-validator": "0.7.6",
    "commander": "14.0.3",
    "drizzle-orm": "1.0.0-beta.20",
    "effect": "3.21.0",
    "es-toolkit": "1.45.1",
    "hono": "4.12.12",
    "parse-git-diff": "0.0.20",
    "picomatch": "^4.0.4",
    "prexit": "2.3.0",
    "ulid": "3.0.2",
    "web-push": "^3.6.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@ccv/testing": "workspace:*",
    "@effect/language-service": "0.84.2",
    "@effect/vitest": "^0.29.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.11",
    "@types/picomatch": "^4.0.3",
    "@types/web-push": "^3.6.4",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "dotenv": "17.4.0",
    "drizzle-kit": "1.0.0-beta.20",
    "vitest": "4.1.2"
  },
  "optionalDependencies": {
    "@replit/ruspty": "3.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
