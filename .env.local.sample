DEV_FE_PORT=3400
DEV_BE_PORT=3401

# Authentication password
CCV_AUTH_PASSWORD=your-secure-password-here

# Server hostname (use 0.0.0.0 to bind to all interfaces for remote access)
# HOSTNAME=localhost

# Peer Sync bearer token (>= 32 chars). Required to enable /api/peer LAN endpoints.
# Generate: openssl rand -base64 24
# CCV_SYNC_TOKEN=replace-with-a-32-plus-char-secret-string
